<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PMS</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- TOP BAR 1 (BLUE) -->
    <div class="topbar-primary">
        <span class="logo">Property Management System</span>
    </div>

    <!-- TOP BAR 2 (WHITE - MODULES) -->
    <div class="topbar-secondary">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <a asp-controller="Customers" asp-action="Index">Customers</a>
        <a asp-controller="Plots" asp-action="Index">Plots</a>
        <a asp-controller="Payments" asp-action="Index">Payments</a>
        <a asp-controller="Schedules" asp-action="Index">Schedules</a>
        <a asp-controller="Transfers" asp-action="Index">Transfers</a>
        <a asp-controller="Setup" asp-action="Index">Setup</a>
    </div>

    <!-- MAIN AREA -->
    <div class="main-container">
        <!-- SIDEBAR -->
        <div class="sidebar">
            @if (ViewBag.ActiveModule == "Customers")
            {
                <ul>
                    <li>Active Customers</li>
                    <li>Blocked Customers</li>
                    <li>Allotted Customers</li>
                    <li>Not Allotted Customers</li>
                    <li>Reports</li>
                </ul>
            }
            else
            {
                <p>Select a module</p>
            }
        </div>

        <!-- PAGE CONTENT -->
        <div class="content-area">
            @RenderBody()
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        © 2026 Property Management System
    </div>

</body>
</html>
